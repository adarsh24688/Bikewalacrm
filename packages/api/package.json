    "bullmq": "^5.7.0",
    "dotenv": "^16.4.0",
    "fastify": "^4.27.0",
    "fastify-plugin": "^4.5.0",
    "imagekit": "^6.0.0",
    "ioredis": "^5.4.0",
    "jsonwebtoken": "^9.0.2",
    "openai": "^6.27.0",
    "pdfkit": "^0.17.2",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.12.0",
    "@types/pdfkit": "^0.17.5",
    "prisma": "^5.14.0",
    "tsx": "^4.11.0",
    "typescript": "^5.4.0"
